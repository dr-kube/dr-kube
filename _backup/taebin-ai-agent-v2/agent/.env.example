# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# Kubernetes 설정
KUBECONFIG_PATH=/path/to/kubeconfig  # 선택사항, 기본값은 ~/.kube/config

# Loki 설정
LOKI_URL=http://localhost:3100

# Git 저장소 설정
GIT_REPO_PATH=/path/to/git/repository

# ArgoCD 설정
ARGOCD_APP_NAME=application-name

# 로깅 레벨
LOG_LEVEL=INFO
