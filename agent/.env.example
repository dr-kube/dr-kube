# LLM 프로바이더 설정 (우선순위: GitHub Copilot → Gemini → Ollama)

# GitHub Copilot 설정 (GITHUB_TOKEN이 있으면 최우선 사용)
# https://github.com/settings/tokens 에서 발급 (Copilot 권한 필요)
# GITHUB_TOKEN=ghp_your-token-here
# COPILOT_MODEL=o3       # 기본값. gpt-4o, claude-sonnet-4-5 등도 가능

# Ollama 설정 (폴백)
OLLAMA_MODEL=qwen2.5:14b

# Gemini 설정 (GITHUB_TOKEN 없을 때)
GEMINI_API_KEY=your-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# 웹훅 서버 설정
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
AUTO_PR=false

# Slack 코파일럿 모드 (SLACK_BOT_TOKEN 설정 시 자동 활성화)
# Slack App 설정 필요:
#   1. https://api.slack.com/apps 에서 앱 생성
#   2. OAuth & Permissions → Bot Token Scopes: chat:write, chat:update, views:open
#   3. Interactivity & Shortcuts → Request URL: https://{your-domain}/webhook/slack/action
#   4. Bot User OAuth Token 복사 (xoxb-로 시작)
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_CHANNEL=#dr-kube
# COPILOT_MODE=true
