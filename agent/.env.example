# LLM 프로바이더 설정
# copilot (GitHub Copilot Pro/Business/Enterprise) 권장
LLM_PROVIDER=copilot

# GitHub Copilot 설정 (LLM_PROVIDER=copilot일 때)
# gh auth token 으로 획득
COPILOT_TOKEN=gho_your-token-here
COPILOT_MODEL=gpt-5.3-codex

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL=C0000000000
COPILOT_MODE=true

# 웹훅 서버 설정
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8081
AUTO_PR=false
